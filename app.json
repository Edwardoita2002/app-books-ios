{
  "expo": {
    "name": "Mi Lector PDF",
    "owner": "edyt800s-team",
    "slug": "edwardo",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.edwardo.pdfreaderapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.edwardo.pdfreaderapp",
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "49f115af-f076-4a0e-849e-5883deca2c52"
      }
    },
    "plugins": [
      "expo-sqlite"
    ]
  }
}
